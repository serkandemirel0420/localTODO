{
  "expo": {
    "name": "Local Todo",
    "slug": "local-todo",
    "scheme": "com.localtodo.app",
    "version": "1.0.3",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F7F4EF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.localtodo.app"
    },
    "android": {
      "package": "com.localtodo.app",
      "versionCode": 4,
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "96b6e215-1b7a-4c22-b921-c3c59cc47d38"
      }
    }
  }
}
